	quest.16A932D4F613DAAD.title: "Craft the Echo Key"
	quest.19C3881A3D5BEBA5.title: "Find a Bastion Remnant"
	quest.1D742C356E8AB2FE.quest_desc: [
		"Split Dimensions is a mod about progressing through different the world one dimension at a time."
		""
		"The primary goal is to bring you the player an experience of each of the wild and crazy experiences that exist in whole custom dimensions that the modding community has created."
		""
		"Start by looking through this initial quest chapter and reading about different sections of the mod and where to start!"
	]
	quest.1D742C356E8AB2FE.quest_subtitle: "Let's get started"
	quest.1D742C356E8AB2FE.title: "Welcome to Split Dimensions!"
	quest.1E94BF843BBC007D.quest_desc: ["This modpack is focused on adventure and exploration with a direct progression system built in allowing you to move through many different dimension mods."]
	quest.1E94BF843BBC007D.quest_subtitle: "Welcome to Roguelike Dimensions!"
	quest.21DCA656A3F8D368.quest_desc: ["To start you are going to need to get a crafting table just like in vanilla minecraft."]
	quest.21DCA656A3F8D368.quest_subtitle: "Humble Beginning..."
	quest.238C74462BD4C631.title: "Mine Cloggrum"
	quest.26D5313F86429851.quest_desc: [
