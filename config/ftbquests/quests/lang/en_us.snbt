	quest.11A973B524829B5F.quest_desc: [
		"Welcome, Rogue."
		""
		"This world is dangerous. Each dimension you explore will be harder than the last."
		""
		"Follow the quest chain in order. Each chapter unlocks the next."
		""
		"§eTODO: Replace this description with your lore text.§r"
